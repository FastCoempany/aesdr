# ═══ AESDR environment variables ═══
# Copy to .env.local for local dev. All vars below must ALSO be set in Vercel
# (Settings → Environment Variables) for production.

# ─── Supabase (Database + Auth) ───
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── Stripe (Payments) ───
# Test mode for sandbox, prod keys for launch
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_SDR=price_...
STRIPE_PRICE_ID_AE=price_...
STRIPE_PRICE_ID_TEAM=price_...
STRIPE_PRICE_ID_ARTIFACT_UNLOCK=price_...

# ─── Resend (Transactional Email) ───
RESEND_API_KEY=re_...

# ─── Site config ───
NEXT_PUBLIC_SITE_URL=https://aesdr.com

# ─── Launch flip (pre-launch = false, launch day = true) ───
# Controls robots.txt, <meta robots>, and search indexing.
NEXT_PUBLIC_LAUNCH_MODE=false

# ─── Optional: Upstash Redis (rate limiting) ───
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Optional: Anthropic (AI features, if any) ───
ANTHROPIC_API_KEY=

# ─── Optional: Sentry (error monitoring) ───
# DSN values come from Sentry → Project Settings → Client Keys (DSN).
# AUTH_TOKEN is for source-map upload at build time and is build-only.
# When unset, Sentry init is a no-op — the app still works.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
